# Public site origin — used for canonical URLs, OG tags, sitemap, robots.
NEXT_PUBLIC_SITE_URL=https://carsablanca.example

# Local Postgres for Drizzle commands and server-side data access.
DATABASE_URL=postgresql://carsablanca:carsablanca@localhost:5432/carsablanca

# PostHog (EU cloud assumed; events route through the first-party /ingest
# proxy — see next.config.ts). Without the key, analytics silently no-op.
NEXT_PUBLIC_POSTHOG_KEY=
# Only needed for non-EU cloud:
# NEXT_PUBLIC_POSTHOG_UI_HOST=https://us.posthog.com
# POSTHOG_INGEST_HOST=https://us.i.posthog.com
# POSTHOG_ASSETS_HOST=https://us-assets.i.posthog.com
